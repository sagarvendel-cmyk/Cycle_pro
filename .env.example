# --- Supabase (Dashboard → Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://mhwmbcjsezzyisdesjgc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_F0NQn3icy0EaffgtX5134w_ylOdXd1U

# Optional: fixed redirect base for email flows (sign-up confirmation, password reset).
# If unset, the app uses the current browser origin at runtime.
# Must match entries in Supabase → Authentication → URL Configuration:
#   Site URL: e.g. http://localhost:3000 (dev) or https://your-domain.com (prod)
#   Redirect URLs (add each):
#     http://localhost:3000/auth/callback
#     http://localhost:3000/auth/reset-password
#     https://your-domain.com/auth/callback
#     https://your-domain.com/auth/reset-password
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=

# --- Vercel Blob (profile image upload via /api/upload) ---
# Dashboard → Storage → Blob → connect project → copy read/write token.
# Required for POST /api/upload in production; optional locally if you skip avatar upload.
BLOB_READ_WRITE_TOKEN=

